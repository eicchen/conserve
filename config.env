# Global project config — edit this file to switch models or override paths.
# All scripts (shell and Python) read from here via config.sh / profiling/config.py.
# Env vars set before running a script take precedence over these defaults.
#
# To switch models, uncomment one of the MODEL lines below (or set MODEL= in your shell).

MODEL=Qwen/Qwen3-0.6B
# MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# Paths are resolved relative to the repo root if not absolute; absolute paths are used as-is.
# On a new machine, adjust MODEL_DIR and MODELS_ROOT to match local storage layout.
MODEL_DIR=models
MODELS_ROOT=model_outputs
# GPU type for profiling data isolation. Switch to H100 when running on H100s.
GPU_TYPE=A40
GPU_MON_ROOT=profiling/gpu_profiling/A40
